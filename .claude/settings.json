      "Bash(ruff check:*)",
      "Bash(pip list:*)",
      "Bash(cat pyproject.toml:*)",
      "Read(//dev/**)",
      "Bash(ls /home/tomo/Workspace/shorts-producer/frontend/app/\\\\\\(app\\\\\\)/)",
