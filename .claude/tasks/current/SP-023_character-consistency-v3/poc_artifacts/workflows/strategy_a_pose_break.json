{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {"ckpt_name": "noobaiXLNAIXL_vPred10Version.safetensors"}
  },
  "2": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0], "clip": ["1", 1],
      "lora_name": "noobai_vpred_1_flat_color_v2.safetensors",
      "strength_model": 0.7, "strength_clip": 0.7
    }
  },
  "3": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["2", 0], "clip": ["2", 1],
      "lora_name": "NOOB_vp1_detailer_by_volnovik_v1.safetensors",
      "strength_model": 0.2, "strength_clip": 0.2
    }
  },
  "4": {
    "class_type": "DynamicThresholdingFull",
    "inputs": {
      "model": ["3", 0],
      "mimic_scale": 5.0, "threshold_percentile": 1.0,
      "mimic_mode": "Half Cosine Down", "mimic_scale_min": 3.0,
      "cfg_mode": "Half Cosine Down", "cfg_scale_min": 3.0,
      "sched_val": 1.0, "separate_feature_channels": "enable",
      "scaling_startpoint": "MEAN", "variability_measure": "AD", "interpolate_phi": 1.0
    }
  },
  "5": {
    "class_type": "ControlNetLoader",
    "inputs": {"control_net_name": "noobaiXLControlnet_openposeModel.safetensors"}
  },
  "6": {
    "class_type": "LoadImage",
    "inputs": {"image": "pose_2p_walking.png"}
  },
  "7": {
    "class_type": "ControlNetApply",
    "inputs": {
      "conditioning": ["10", 0],
      "control_net": ["5", 0],
      "image": ["6", 0],
      "strength": 0.7
    }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive (BREAK 구조)"},
    "inputs": {
      "clip": ["3", 1],
      "text": "masterpiece, best_quality, high_quality, 1boy, 1girl, walking together on a tree-lined street, side by side, warm afternoon lighting, detailed urban background, autumn\nBREAK\n1girl, light_brown_hair, long_hair, side_swept_bangs, brown_eyes, white_cardigan, light_blue_blouse, hair_ribbon, slight_smile, young_woman, on the left\nBREAK\n1boy, dark_brown_hair, short_hair, curtained_hair, brown_eyes, white_shirt, navy_cardigan, rolled_up_sleeves, gentle_smile, young_man, tall, on the right"
    }
  },
  "20": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative"},
    "inputs": {
      "clip": ["3", 1],
      "text": "worst_quality, low_quality, bad_anatomy, bad_hands, blurry, watermark, text, speech_bubble, comic, manga, 3d, realistic, child, loli, chibi, extra_people, 3people, monochrome"
    }
  },
  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {"width": 832, "height": 1216, "batch_size": 1}
  },
  "40": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["4", 0],
      "positive": ["7", 0],
      "negative": ["20", 0],
      "latent_image": ["30", 0],
      "seed": 100,
      "steps": 28,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "50": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["40", 0], "vae": ["1", 2]}
  },
  "60": {
    "class_type": "SaveImage",
    "inputs": {"images": ["50", 0], "filename_prefix": "2p_pose_break"}
  }
}
