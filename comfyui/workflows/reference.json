{
  "_meta": {
    "name": "Character Reference",
    "description": "캐릭터 레퍼런스 이미지 생성 — 상반신, 정면, 단순 배경. DynamicThresholding 필수 (NoobAI v-pred)",
    "version": "2.0.0",
    "author": "shorts-producer",
    "variables": {
      "{{positive}}": "캐릭터 프롬프트 (flat color 트리거 포함)",
      "{{negative}}": "네거티브 프롬프트",
      "{{checkpoint}}": "체크포인트 파일명",
      "{{lora_name}}": "스타일 LoRA 파일명",
      "{{lora_strength}}": "LoRA 가중치 (0.0~1.0)",
      "{{seed}}": "시드 (-1 = 랜덤)",
      "{{width}}": "이미지 너비",
      "{{height}}": "이미지 높이"
    },
    "output_node": "9_save"
  },
  "1_checkpoint": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{checkpoint}}"
    }
  },
  "2_lora": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "{{lora_name}}",
      "strength_model": "{{lora_strength}}",
      "strength_clip": "{{lora_strength}}",
      "model": ["1_checkpoint", 0],
      "clip": ["1_checkpoint", 1]
    }
  },
  "3_dynthres": {
    "class_type": "DynamicThresholdingFull",
    "inputs": {
      "model": ["2_lora", 0],
      "mimic_scale": 5.0,
      "threshold_percentile": 1.0,
      "mimic_mode": "Half Cosine Down",
      "mimic_scale_min": 1.0,
      "cfg_mode": "Half Cosine Down",
      "cfg_scale_min": 3.0,
      "sched_val": 1.0,
      "separate_feature_channels": "enable",
      "scaling_startpoint": "ZERO",
      "variability_measure": "STD",
      "interpolate_phi": 1.0
    }
  },
  "4_positive": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive}}",
      "clip": ["2_lora", 1]
    }
  },
  "5_negative": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative}}",
      "clip": ["2_lora", 1]
    }
  },
  "6_latent": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    }
  },
  "7_sampler": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{seed}}",
      "steps": 28,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "model": ["3_dynthres", 0],
      "positive": ["4_positive", 0],
      "negative": ["5_negative", 0],
      "latent_image": ["6_latent", 0]
    }
  },
  "8_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7_sampler", 0],
      "vae": ["1_checkpoint", 2]
    }
  },
  "9_save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "SP_ref",
      "images": ["8_decode", 0]
    }
  }
}
