{
  "_meta": {
    "name": "Scene 2-Person Regional",
    "description": "2인 씬 — Regional Conditioning (좌/우 영역 분리), LoRA 2슬롯, DynamicThresholding",
    "version": "0.1.0-prototype",
    "variables": {
      "{{positive_bg}}": "배경/환경 프롬프트 (전체 영역)",
      "{{positive_a}}": "캐릭터A 프롬프트 (좌측)",
      "{{positive_b}}": "캐릭터B 프롬프트 (우측)",
      "{{negative}}": "네거티브 프롬프트",
      "{{checkpoint}}": "체크포인트 파일명",
      "{{seed}}": "시드",
      "{{width}}": "이미지 너비 (기본 832)",
      "{{height}}": "이미지 높이 (기본 1216)",
      "{{steps}}": "샘플링 스텝 수",
      "{{cfg}}": "CFG 스케일",
      "{{sampler_name}}": "샘플러",
      "{{scheduler}}": "스케줄러"
    },
    "output_node": "15_save"
  },
  "1_checkpoint": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{checkpoint}}"
    }
  },
  "2_lora_style": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["1_checkpoint", 0],
      "clip": ["1_checkpoint", 1]
    }
  },
  "3_lora_detail": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["2_lora_style", 0],
      "clip": ["2_lora_style", 1]
    }
  },
  "4_dynthres": {
    "class_type": "DynamicThresholdingFull",
    "inputs": {
      "model": ["3_lora_detail", 0],
      "mimic_scale": 7.0,
      "threshold_percentile": 1.0,
      "mimic_mode": "Half Cosine Down",
      "mimic_scale_min": 1.0,
      "cfg_mode": "Half Cosine Down",
      "cfg_scale_min": 3.0,
      "sched_val": 1.0,
      "separate_feature_channels": "enable",
      "scaling_startpoint": "ZERO",
      "variability_measure": "STD",
      "interpolate_phi": 1.0
    }
  },

  "5_clip_bg": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_bg}}",
      "clip": ["3_lora_detail", 1]
    }
  },
  "6_clip_a": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_a}}",
      "clip": ["3_lora_detail", 1]
    }
  },
  "7_clip_b": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_b}}",
      "clip": ["3_lora_detail", 1]
    }
  },
  "8_negative": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative}}",
      "clip": ["3_lora_detail", 1]
    }
  },

  "9_region_a": {
    "class_type": "ConditioningSetArea",
    "inputs": {
      "conditioning": ["6_clip_a", 0],
      "width": 448,
      "height": 1216,
      "x": 0,
      "y": 0,
      "strength": 1.0
    }
  },
  "10_region_b": {
    "class_type": "ConditioningSetArea",
    "inputs": {
      "conditioning": ["7_clip_b", 0],
      "width": 448,
      "height": 1216,
      "x": 384,
      "y": 0,
      "strength": 1.0
    }
  },

  "11_combine_ab": {
    "class_type": "ConditioningCombine",
    "inputs": {
      "conditioning_1": ["9_region_a", 0],
      "conditioning_2": ["10_region_b", 0]
    }
  },
  "12_combine_all": {
    "class_type": "ConditioningCombine",
    "inputs": {
      "conditioning_1": ["5_clip_bg", 0],
      "conditioning_2": ["11_combine_ab", 0]
    }
  },

  "13_latent": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    }
  },
  "14_sampler": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{seed}}",
      "steps": "{{steps}}",
      "cfg": "{{cfg}}",
      "sampler_name": "{{sampler_name}}",
      "scheduler": "{{scheduler}}",
      "denoise": 1.0,
      "model": ["4_dynthres", 0],
      "positive": ["12_combine_all", 0],
      "negative": ["8_negative", 0],
      "latent_image": ["13_latent", 0]
    }
  },
  "14_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["14_sampler", 0],
      "vae": ["1_checkpoint", 2]
    }
  },
  "15_save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "SP_2p",
      "images": ["14_decode", 0]
    }
  }
}
