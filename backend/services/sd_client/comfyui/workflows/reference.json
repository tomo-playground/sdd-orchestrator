{
  "_meta": {
    "name": "Character Reference — NoobXL v-pred",
    "description": "레퍼런스 워크플로우: 2-LoRA (style + detailer), dpmpp_2m + karras",
    "version": "4.0.0",
    "variables": {
      "{{positive}}": "캐릭터 프롬프트",
      "{{negative}}": "네거티브 프롬프트",
      "{{checkpoint}}": "체크포인트 파일명",
      "{{seed}}": "시드",
      "{{width}}": "이미지 너비",
      "{{height}}": "이미지 높이",
      "{{steps}}": "샘플링 스텝 수",
      "{{cfg}}": "CFG 스케일",
      "{{sampler_name}}": "샘플러",
      "{{scheduler}}": "스케줄러"
    },
    "output_node": "9_save"
  },
  "1_checkpoint": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{checkpoint}}"
    }
  },
  "2_lora_style": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["1_checkpoint", 0],
      "clip": ["1_checkpoint", 1]
    }
  },
  "3_lora_detailer": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["2_lora_style", 0],
      "clip": ["2_lora_style", 1]
    }
  },
  "4_positive": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive}}",
      "clip": ["3_lora_detailer", 1]
    }
  },
  "5_negative": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative}}",
      "clip": ["3_lora_detailer", 1]
    }
  },
  "6_latent": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    }
  },
  "7_sampler": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{seed}}",
      "steps": "{{steps}}",
      "cfg": "{{cfg}}",
      "sampler_name": "{{sampler_name}}",
      "scheduler": "{{scheduler}}",
      "denoise": 1.0,
      "model": ["3_lora_detailer", 0],
      "positive": ["4_positive", 0],
      "negative": ["5_negative", 0],
      "latent_image": ["6_latent", 0]
    }
  },
  "8_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7_sampler", 0],
      "vae": ["1_checkpoint", 2]
    }
  },
  "9_save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "SP_ref",
      "images": ["8_decode", 0]
    }
  }
}
