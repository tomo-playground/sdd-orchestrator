{
  "_meta": {
    "name": "Scene Single Character",
    "description": "1인 씬 이미지 생성 — 세로형, LoRA 3슬롯 (스타일+캐릭터+추가), DynamicThresholding, 듀얼 IP-Adapter (배경+캐릭터)",
    "version": "2.0.0",
    "author": "shorts-producer",
    "variables": ["positive", "negative", "checkpoint", "seed", "width", "height", "steps", "cfg", "sampler_name", "scheduler", "ip_adapter_image", "ip_adapter_weight", "ip_adapter_end_at", "bg_ref_image", "bg_mask", "char_mask", "bg_ip_adapter_weight", "bg_ip_adapter_end_at"],
    "output_node": "11_save"
  },
  "1_checkpoint": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{checkpoint}}"
    }
  },
  "2_lora_style": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["1_checkpoint", 0],
      "clip": ["1_checkpoint", 1]
    }
  },
  "3_lora_char": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["2_lora_style", 0],
      "clip": ["2_lora_style", 1]
    }
  },
  "4_lora_extra": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "placeholder.safetensors",
      "strength_model": 0,
      "strength_clip": 0,
      "model": ["3_lora_char", 0],
      "clip": ["3_lora_char", 1]
    }
  },
  "5_dynthres": {
    "class_type": "DynamicThresholdingFull",
    "inputs": {
      "model": ["4_lora_extra", 0],
      "mimic_scale": 7.0,
      "threshold_percentile": 1.0,
      "mimic_mode": "Half Cosine Down",
      "mimic_scale_min": 1.0,
      "cfg_mode": "Half Cosine Down",
      "cfg_scale_min": 3.0,
      "sched_val": 1.0,
      "separate_feature_channels": "enable",
      "scaling_startpoint": "ZERO",
      "variability_measure": "STD",
      "interpolate_phi": 1.0
    }
  },
  "6_positive": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive}}",
      "clip": ["4_lora_extra", 1]
    }
  },
  "7_negative": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative}}",
      "clip": ["4_lora_extra", 1]
    }
  },
  "8_latent": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    }
  },
  "9_sampler": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{seed}}",
      "steps": "{{steps}}",
      "cfg": "{{cfg}}",
      "sampler_name": "{{sampler_name}}",
      "scheduler": "{{scheduler}}",
      "denoise": 1.0,
      "model": ["14_ip_apply", 0],
      "positive": ["6_positive", 0],
      "negative": ["7_negative", 0],
      "latent_image": ["8_latent", 0]
    }
  },
  "12_ip_model": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "NOOB-IPA-MARK1.safetensors"
    }
  },
  "12b_clip_vision": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "CLIP-ViT-bigG-14-laion2B-39B-b160k.safetensors"
    }
  },
  "13_ip_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{ip_adapter_image}}"
    }
  },
  "13b_char_mask_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{char_mask}}"
    }
  },
  "13b_char_mask": {
    "class_type": "ImageToMask",
    "inputs": {
      "image": ["13b_char_mask_image", 0],
      "channel": "red"
    }
  },
  "14_ip_apply": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["15_bg_ip_apply", 0],
      "ipadapter": ["12_ip_model", 0],
      "clip_vision": ["12b_clip_vision", 0],
      "image": ["13_ip_image", 0],
      "attn_mask": ["13b_char_mask", 0],
      "weight": "{{ip_adapter_weight}}",
      "weight_type": "linear",
      "start_at": 0.0,
      "end_at": "{{ip_adapter_end_at}}",
      "combine_embeds": "concat",
      "embeds_scaling": "V only"
    }
  },
  "15_bg_ref_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{bg_ref_image}}"
    }
  },
  "15b_bg_mask_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{bg_mask}}"
    }
  },
  "15c_bg_mask": {
    "class_type": "ImageToMask",
    "inputs": {
      "image": ["15b_bg_mask_image", 0],
      "channel": "red"
    }
  },
  "15_bg_ip_apply": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["5_dynthres", 0],
      "ipadapter": ["12_ip_model", 0],
      "clip_vision": ["12b_clip_vision", 0],
      "image": ["15_bg_ref_image", 0],
      "attn_mask": ["15c_bg_mask", 0],
      "weight": "{{bg_ip_adapter_weight}}",
      "weight_type": "linear",
      "start_at": 0.0,
      "end_at": "{{bg_ip_adapter_end_at}}",
      "combine_embeds": "concat",
      "embeds_scaling": "V only"
    }
  },
  "10_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9_sampler", 0],
      "vae": ["1_checkpoint", 2]
    }
  },
  "11_save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "SP_scene",
      "images": ["10_decode", 0]
    }
  }
}
