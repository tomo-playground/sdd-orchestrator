# ============================================================
# Shorts Producer — Backend 환경 변수
# 이 파일을 복사하여 .env로 사용: cp .env.example .env
# ============================================================

# --- 필수 (Required) ---

# 애플리케이션 환경 (development | staging | production | test)
APP_ENV=development

# PostgreSQL 연결
DATABASE_URL=postgresql://user:password@localhost:5432/shorts_producer
# DB_POOL_SIZE=10                         # Connection Pool 크기
# DB_MAX_OVERFLOW=20                      # Pool 초과 허용 수
# DB_POOL_RECYCLE=1800                    # 연결 재활용 주기 (초)
# DB_POOL_PRE_PING=true                   # stale connection 자동 감지

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# --- 스토리지 (MinIO/S3) ---
STORAGE_MODE=s3                          # 's3' | 'local'
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123456        # 12자 이상 권장
MINIO_BUCKET=shorts-producer
STORAGE_PUBLIC_URL=http://localhost:9000

# --- 외부 서비스 URL ---
COMFYUI_BASE_URL=http://127.0.0.1:8188  # ComfyUI 서버
COMFYUI_NETWORK_TIMEOUT=10              # ComfyUI 네트워크 요청 타임아웃 (초)
COMFYUI_EXECUTION_TIMEOUT=180           # ComfyUI 이미지 다운로드 타임아웃 (초)
COMFYUI_QUEUE_TIMEOUT=300               # ComfyUI 큐 전체 실행 타임아웃 (초)
AUDIO_SERVER_URL=http://127.0.0.1:8001   # TTS/BGM 오디오 서버
API_PUBLIC_URL=http://localhost:8000      # Backend 공개 URL
CORS_ORIGINS=http://localhost:3000       # 쉼표 구분 복수 가능

# --- LangFuse Observability ---
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_TRACING_ENVIRONMENT=development # development | production

# --- Gemini 모델 설정 ---
GEMINI_TEXT_MODEL=gemini-2.5-flash       # 기본 텍스트 모델
GEMINI_FALLBACK_MODEL=gemini-2.0-flash   # PROHIBITED fallback
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
CREATIVE_LEADER_MODEL=gemini-2.5-pro     # Creative Debate 리더
DIRECTOR_MODEL=gemini-2.5-pro            # Director 노드
REVIEW_MODEL=gemini-2.5-pro              # Review 노드
# GEMINI_TIMEOUT_MS=120000               # API 호출 timeout (ms)
# GEMINI_MAX_CONCURRENT=5                # 동시 호출 제한

# --- LLM Provider ---
LLM_PROVIDER=gemini                      # 'gemini' | 'ollama'
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=exaone3.5:7.8b

# --- 로깅 ---
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=1
LOG_FILE=logs/backend.log

# --- YouTube Upload (선택) ---
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=http://localhost:3000/settings/youtube
# YOUTUBE_TOKEN_ENCRYPTION_KEY=

# --- Hugging Face (선택) ---
# HF_TOKEN=hf_...

# --- TTS 설정 (선택) ---
# DEFAULT_TTS_ENGINE=qwen               # 'qwen' | 'sovits'
# TTS_PRELOAD_MODEL=false
# TTS_ATTN_IMPLEMENTATION=eager

# --- Sentry Error Monitoring (선택) ---
# SENTRY_DSN_BACKEND=https://xxx@xxx.ingest.us.sentry.io/xxx
# SENTRY_ENVIRONMENT=development         # development | production
# SENTRY_AUTH_TOKEN=sntryu_...            # Sentry API 순찰 토큰 (sentry-patrol.sh용)

# --- Slack Bot (선택) ---
# SLACK_BOT_TOKEN=xoxb-...               # Bot User OAuth Token
# SLACK_APP_TOKEN=xapp-...               # App-Level Token (Socket Mode)
# SLACK_BOT_ALLOWED_CHANNEL=C0123456789  # 명령 허용 채널 ID (미설정 = 전체 허용)
# SLACK_BOT_ALLOWED_USERS=U0123,U0456   # 허용 사용자 ID 쉼표 구분 (미설정 = 전체 허용)
